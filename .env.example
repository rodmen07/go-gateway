PORT=8091

# Rate limiting (per-client-IP, per-route token bucket)
RATE_LIMIT_RPS=15          # fallback for unclassified routes
RATE_LIMIT_AUTH_RPS=5      # /api/auth/* — credential-stuffing protection
RATE_LIMIT_WRITE_RPS=30    # CRM mutation routes
RATE_LIMIT_READ_RPS=60     # /api/reporting, /api/search, /api/events

# Upstream service URLs (defaults to live Fly.io URLs if unset)
TASKS_URL=https://backend-service-rodmen07-v2.fly.dev
ACCOUNTS_URL=https://accounts-service.fly.dev
CONTACTS_URL=https://contacts-service.fly.dev
OPPORTUNITIES_URL=https://taskforge-opportunities-service.fly.dev
ACTIVITIES_URL=https://taskforge-activities-service.fly.dev
AUTOMATION_URL=https://taskforge-automation-service.fly.dev
INTEGRATIONS_URL=https://taskforge-integrations-service.fly.dev
REPORTING_URL=https://taskforge-reporting-service.fly.dev
SEARCH_URL=https://taskforge-search-service.fly.dev
EVENTS_URL=https://observaboard-rodmen07.fly.dev
